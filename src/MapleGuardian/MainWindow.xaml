<Window x:Class="MapleGuardian.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Maple Guardian"
        Icon="Resources/app_icon.ico"
        Width="380" Height="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Boolean to Visibility converters -->
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Main container with rounded corners and border -->
    <Border CornerRadius="16"
            BorderThickness="1"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            Background="{StaticResource BgGradientBrush}">

        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>   <!-- Title Bar -->
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Status Cards -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
                <RowDefinition Height="Auto"/> <!-- Status Bar -->
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- Custom Title Bar                                    -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App title in title bar -->
                <TextBlock Grid.Column="0"
                           Text="  🍁 Maple Guardian"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>

                <!-- Minimize button -->
                <Button Grid.Column="1"
                        Content="─"
                        Style="{StaticResource TitleBarButton}"
                        Click="MinimizeButton_Click"/>

                <!-- Close button (minimize to tray) -->
                <Button Grid.Column="2"
                        Content="✕"
                        Style="{StaticResource CloseButton}"
                        Click="CloseButton_Click"/>
            </Grid>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- Header Section                                      -->
            <!-- ═══════════════════════════════════════════════════ -->
            <StackPanel Grid.Row="1" Margin="24,2,24,10">
                <!-- App Logo Image (Frameless Transparent Emblem) -->
                <Image Source="Resources/logo_clean.png"
                       Width="68" Height="68"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"
                       RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Effect>
                        <DropShadowEffect Color="#FF000000" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                    </Image.Effect>
                </Image>

                <!-- App Name -->
                <TextBlock Text="Maple Guardian"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Professional VPN Kill Switch &amp; Monitor"
                           FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>

                <!-- Separator -->
                <Border Height="1"
                        Background="{StaticResource BorderSubtleBrush}"
                        Margin="0,10,0,0"/>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- Status Dashboard                                    -->
            <!-- ═══════════════════════════════════════════════════ -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          Margin="24,0,24,0">
                <StackPanel>

                    <!-- VPN Status Card -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- VPN icon -->
                            <Border Grid.Column="0"
                                    Width="40" Height="40"
                                    CornerRadius="10"
                                    Margin="0,0,14,0"
                                    VerticalAlignment="Center">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding VpnStatusColor.Color, FallbackValue=#FF484F58}" Opacity="0.15"/>
                                </Border.Background>
                                <TextBlock Text="🛡️"
                                           FontSize="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- VPN text -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="VPN Status"
                                           Style="{StaticResource StatusLabel}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding VpnStatusText}"
                                           Foreground="{Binding VpnStatusColor}"
                                           FontSize="18"
                                           FontWeight="Bold"/>
                            </StackPanel>

                            <!-- Status dot -->
                            <Ellipse Grid.Column="2"
                                     x:Name="VpnDot"
                                     Style="{StaticResource StatusDot}"
                                     Width="12" Height="12">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{Binding VpnStatusColor.Color, FallbackValue=#FF484F58}"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>
                    </Border>

                    <!-- Info Grid Card -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Server -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="🌍  Server"
                                       Style="{StaticResource StatusLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding ServerLocation}"
                                       Style="{StaticResource StatusValue}"/>

                            <!-- Separator -->
                            <Border Grid.Row="1" Grid.ColumnSpan="2"
                                    Height="1" Background="{StaticResource BorderSubtleBrush}"
                                    Margin="0,8"/>

                            <!-- Public IP -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="📡  Public IP"
                                       Style="{StaticResource StatusLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding PublicIp}"
                                       Style="{StaticResource StatusValue}"/>

                            <!-- Separator -->
                            <Border Grid.Row="3" Grid.ColumnSpan="2"
                                    Height="1" Background="{StaticResource BorderSubtleBrush}"
                                    Margin="0,8"/>

                            <!-- IP Type (IDC vs Residential) -->
                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="🏢  IP Type"
                                       Style="{StaticResource StatusLabel}"/>
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding IpTypeIcon}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding IpTypeText}"
                                           Foreground="{Binding IpTypeColor}"
                                           Style="{StaticResource StatusValue}"/>
                            </StackPanel>

                            <!-- Separator -->
                            <Border Grid.Row="5" Grid.ColumnSpan="2"
                                    Height="1" Background="{StaticResource BorderSubtleBrush}"
                                    Margin="0,8"/>

                            <!-- Ping -->
                            <TextBlock Grid.Row="6" Grid.Column="0"
                                       Text="📶  Ping"
                                       Style="{StaticResource StatusLabel}"/>
                            <TextBlock Grid.Row="6" Grid.Column="1"
                                       Text="{Binding PingText}"
                                       Foreground="{Binding PingColor}"
                                       Style="{StaticResource StatusValue}"/>

                            <!-- Separator -->
                            <Border Grid.Row="7" Grid.ColumnSpan="2"
                                    Height="1" Background="{StaticResource BorderSubtleBrush}"
                                    Margin="0,8"/>
                        </Grid>
                    </Border>

                    <!-- Security Status Card -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- DNS -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="🔒  DNS"
                                       Style="{StaticResource StatusLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding DnsStatusText}"
                                       Foreground="{Binding DnsStatusColor}"
                                       Style="{StaticResource StatusValue}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="{Binding DnsStatusIcon}"
                                       FontSize="14" VerticalAlignment="Center"/>

                            <!-- Separator -->
                            <Border Grid.Row="1" Grid.ColumnSpan="3"
                                    Height="1" Background="{StaticResource BorderSubtleBrush}"
                                    Margin="0,8"/>

                            <!-- Firewall -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="🛡️  Firewall"
                                       Style="{StaticResource StatusLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding FirewallStatusText}"
                                       Foreground="{Binding FirewallStatusColor}"
                                       Style="{StaticResource StatusValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="2"
                                       Text="{Binding FirewallStatusIcon}"
                                       FontSize="14" VerticalAlignment="Center"/>

                            <!-- Separator -->
                            <Border Grid.Row="3" Grid.ColumnSpan="3"
                                    Height="1" Background="{StaticResource BorderSubtleBrush}"
                                    Margin="0,8"/>

                            <!-- Game -->
                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="🎮  Game"
                                       Style="{StaticResource StatusLabel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1"
                                       Text="{Binding GameStatusText}"
                                       Foreground="{Binding GameStatusColor}"
                                       Style="{StaticResource StatusValue}"/>
                            <TextBlock Grid.Row="4" Grid.Column="2"
                                       Text="{Binding GameStatusIcon}"
                                       FontSize="14" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- Action Buttons                                      -->
            <!-- ═══════════════════════════════════════════════════ -->
            <StackPanel Grid.Row="3" Margin="24,10,24,10" Orientation="Vertical">

                <!-- Reconnect Button -->
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding ReconnectVpnCommand}"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄  Reconnect VPN" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Button Row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Open Logs -->
                    <Button Grid.Column="0"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding OpenLogsCommand}">
                        <TextBlock Text="📋 Logs" FontSize="12"/>
                    </Button>

                    <!-- Startup Toggle -->
                    <Button Grid.Column="2"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ToggleStartupCommand}">
                        <TextBlock FontSize="12">
                            <Run Text="⚙️"/>
                            <Run Text="{Binding StartWithWindows, Mode=OneWay, StringFormat='{}Startup: {0}'}"/>
                        </TextBlock>
                    </Button>

                    <!-- Exit -->
                    <Button Grid.Column="4"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding ExitAppCommand}">
                        <TextBlock Text="❌ Exit" FontSize="12"/>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- Status Bar                                          -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Grid.Row="4"
                    Background="#10FFFFFF"
                    CornerRadius="0,0,16,16"
                    Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusBarText}"
                               Foreground="{Binding StatusBarColor}"
                               FontSize="11"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding UptimeText, StringFormat='⏱ {0}'}"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- In-App Log Viewer Overlay Panel                     -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Grid.RowSpan="5"
                  Background="#F00D1117"
                  Visibility="{Binding IsLogViewerOpen, Converter={StaticResource BoolToVis}}"
                  Panel.ZIndex="100">
                <Border Margin="12,12,12,12"
                        Background="#161B22"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header -->
                            <RowDefinition Height="*"/>    <!-- Log List -->
                            <RowDefinition Height="Auto"/> <!-- Actions -->
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📋 Application Logs"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="13"/>
                                <Border Margin="8,0,0,0" Padding="6,2" Background="#21262D" CornerRadius="4">
                                    <TextBlock Text="{Binding LogEntries.Count, StringFormat='{}{0} entries'}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11"/>
                                </Border>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="✕"
                                    Command="{Binding CloseLogViewerCommand}"
                                    Width="26" Height="26"
                                    Background="Transparent"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    BorderThickness="0"
                                    FontSize="13"
                                    Cursor="Hand"/>
                        </Grid>

                        <!-- Log Entries ListBox -->
                        <Border Grid.Row="1"
                                Background="#0D1117"
                                BorderBrush="#30363D"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="4">
                            <ListBox x:Name="LogListBox"
                                     ItemsSource="{Binding LogEntries}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Timestamp -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Timestamp, StringFormat='[{0:HH:mm:ss}]'}"
                                                       Foreground="#8B949E"
                                                       FontFamily="Consolas, Cascadia Code, Courier New"
                                                       FontSize="11"
                                                       Margin="0,0,6,0"/>

                                            <!-- Level -->
                                            <Border Grid.Column="1" Margin="0,0,6,0" Padding="4,1" CornerRadius="3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#21262D"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Level}" Value="INF">
                                                                <Setter Property="Background" Value="#1F3A2B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="WRN">
                                                                <Setter Property="Background" Value="#3D2E0F"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="ERR">
                                                                <Setter Property="Background" Value="#3D1A1A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Level}"
                                                           FontFamily="Consolas, Cascadia Code, Courier New"
                                                           FontSize="10"
                                                           FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#8B949E"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Level}" Value="INF">
                                                                    <Setter Property="Foreground" Value="#3FB950"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Level}" Value="WRN">
                                                                    <Setter Property="Foreground" Value="#D29922"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Level}" Value="ERR">
                                                                    <Setter Property="Foreground" Value="#F85149"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <!-- Message -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Message}"
                                                       Foreground="#C9D1D9"
                                                       FontFamily="Consolas, Cascadia Code, Courier New"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <!-- Bottom Actions -->
                        <Grid Grid.Row="2" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Button Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CopyLogsCommand}"
                                        Padding="10,4" Margin="0,0,6,0">
                                    <TextBlock Text="📋 Copy" FontSize="11"/>
                                </Button>
                                <Button Style="{StaticResource SecondaryButton}"
                                        Command="{Binding ClearLogsCommand}"
                                        Padding="10,4" Margin="0,0,6,0">
                                    <TextBlock Text="🗑 Clear" FontSize="11"/>
                                </Button>
                                <Button Style="{StaticResource SecondaryButton}"
                                        Command="{Binding OpenLogsFolderCommand}"
                                        Padding="10,4">
                                    <TextBlock Text="📁 Folder" FontSize="11"/>
                                </Button>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding CloseLogViewerCommand}"
                                    Padding="14,4">
                                <TextBlock Text="Close" FontSize="11"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

        </Grid>
    </Border>
</Window>
