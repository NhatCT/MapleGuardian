<Window x:Class="MapleGuardian.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Maple Guardian"
        Width="380" Height="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Boolean to Visibility converters -->
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Main container with rounded corners and border -->
    <Border CornerRadius="16"
            BorderThickness="1"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            Background="{StaticResource BgGradientBrush}">

        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>   <!-- Title Bar -->
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Status Cards -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
                <RowDefinition Height="Auto"/> <!-- Status Bar -->
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- Custom Title Bar                                    -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App title in title bar -->
                <TextBlock Grid.Column="0"
                           Text="  🍁 Maple Guardian"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>

                <!-- Minimize button -->
                <Button Grid.Column="1"
                        Content="─"
                        Style="{StaticResource TitleBarButton}"
                        Click="MinimizeButton_Click"/>

                <!-- Close button (minimize to tray) -->
                <Button Grid.Column="2"
                        Content="✕"
                        Style="{StaticResource CloseButton}"
                        Click="CloseButton_Click"/>
            </Grid>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- Header Section                                      -->
            <!-- ═══════════════════════════════════════════════════ -->
            <StackPanel Grid.Row="1" Margin="24,2,24,10">
                <!-- App Logo Image -->
                <Border Width="64" Height="64"
                        CornerRadius="16"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,8"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#FF000000" BlurRadius="12" ShadowDepth="2" Opacity="0.4"/>
                    </Border.Effect>
                    <Border.Background>
                        <ImageBrush ImageSource="Resources/logo.png" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>

                <!-- App Name -->
                <TextBlock Text="Maple Guardian"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Professional VPN Kill Switch &amp; Monitor"
                           FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>

                <!-- Separator -->
                <Border Height="1"
                        Background="{StaticResource BorderSubtleBrush}"
                        Margin="0,10,0,0"/>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- Status Dashboard                                    -->
            <!-- ═══════════════════════════════════════════════════ -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          Margin="24,0,24,0">
                <StackPanel>

                    <!-- VPN Status Card -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- VPN icon -->
                            <Border Grid.Column="0"
                                    Width="40" Height="40"
                                    CornerRadius="10"
                                    Margin="0,0,14,0"
                                    VerticalAlignment="Center">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding VpnStatusColor.Color, FallbackValue=#FF484F58}" Opacity="0.15"/>
                                </Border.Background>
                                <TextBlock Text="🛡️"
                                           FontSize="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- VPN text -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="VPN Status"
                                           Style="{StaticResource StatusLabel}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding VpnStatusText}"
                                           Foreground="{Binding VpnStatusColor}"
                                           FontSize="18"
                                           FontWeight="Bold"/>
                            </StackPanel>

                            <!-- Status dot -->
                            <Ellipse Grid.Column="2"
                                     x:Name="VpnDot"
                                     Style="{StaticResource StatusDot}"
                                     Width="12" Height="12">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{Binding VpnStatusColor.Color, FallbackValue=#FF484F58}"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>
                    </Border>

                    <!-- Info Grid Card -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Server -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="🌍  Server"
                                       Style="{StaticResource StatusLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding ServerLocation}"
                                       Style="{StaticResource StatusValue}"/>

                            <!-- Separator -->
                            <Border Grid.Row="1" Grid.ColumnSpan="2"
                                    Height="1" Background="{StaticResource BorderSubtleBrush}"
                                    Margin="0,8"/>

                            <!-- Public IP -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="📡  Public IP"
                                       Style="{StaticResource StatusLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding PublicIp}"
                                       Style="{StaticResource StatusValue}"/>

                            <!-- Separator -->
                            <Border Grid.Row="3" Grid.ColumnSpan="2"
                                    Height="1" Background="{StaticResource BorderSubtleBrush}"
                                    Margin="0,8"/>

                            <!-- IP Type (IDC vs Residential) -->
                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="🏢  IP Type"
                                       Style="{StaticResource StatusLabel}"/>
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding IpTypeIcon}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding IpTypeText}"
                                           Foreground="{Binding IpTypeColor}"
                                           Style="{StaticResource StatusValue}"/>
                            </StackPanel>

                            <!-- Separator -->
                            <Border Grid.Row="5" Grid.ColumnSpan="2"
                                    Height="1" Background="{StaticResource BorderSubtleBrush}"
                                    Margin="0,8"/>

                            <!-- Ping -->
                            <TextBlock Grid.Row="6" Grid.Column="0"
                                       Text="📶  Ping"
                                       Style="{StaticResource StatusLabel}"/>
                            <TextBlock Grid.Row="6" Grid.Column="1"
                                       Text="{Binding PingText}"
                                       Foreground="{Binding PingColor}"
                                       Style="{StaticResource StatusValue}"/>

                            <!-- Separator -->
                            <Border Grid.Row="7" Grid.ColumnSpan="2"
                                    Height="1" Background="{StaticResource BorderSubtleBrush}"
                                    Margin="0,8"/>
                        </Grid>
                    </Border>

                    <!-- Security Status Card -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- DNS -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="🔒  DNS"
                                       Style="{StaticResource StatusLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding DnsStatusText}"
                                       Foreground="{Binding DnsStatusColor}"
                                       Style="{StaticResource StatusValue}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="{Binding DnsStatusIcon}"
                                       FontSize="14" VerticalAlignment="Center"/>

                            <!-- Separator -->
                            <Border Grid.Row="1" Grid.ColumnSpan="3"
                                    Height="1" Background="{StaticResource BorderSubtleBrush}"
                                    Margin="0,8"/>

                            <!-- Firewall -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="🛡️  Firewall"
                                       Style="{StaticResource StatusLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding FirewallStatusText}"
                                       Foreground="{Binding FirewallStatusColor}"
                                       Style="{StaticResource StatusValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="2"
                                       Text="{Binding FirewallStatusIcon}"
                                       FontSize="14" VerticalAlignment="Center"/>

                            <!-- Separator -->
                            <Border Grid.Row="3" Grid.ColumnSpan="3"
                                    Height="1" Background="{StaticResource BorderSubtleBrush}"
                                    Margin="0,8"/>

                            <!-- Game -->
                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="🎮  Game"
                                       Style="{StaticResource StatusLabel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1"
                                       Text="{Binding GameStatusText}"
                                       Foreground="{Binding GameStatusColor}"
                                       Style="{StaticResource StatusValue}"/>
                            <TextBlock Grid.Row="4" Grid.Column="2"
                                       Text="{Binding GameStatusIcon}"
                                       FontSize="14" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- Action Buttons                                      -->
            <!-- ═══════════════════════════════════════════════════ -->
            <StackPanel Grid.Row="3" Margin="24,10,24,10" Orientation="Vertical">

                <!-- Reconnect Button -->
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding ReconnectVpnCommand}"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄  Reconnect VPN" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Button Row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Open Logs -->
                    <Button Grid.Column="0"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding OpenLogsCommand}">
                        <TextBlock Text="📋 Logs" FontSize="12"/>
                    </Button>

                    <!-- Startup Toggle -->
                    <Button Grid.Column="2"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ToggleStartupCommand}">
                        <TextBlock FontSize="12">
                            <Run Text="⚙️"/>
                            <Run Text="{Binding StartWithWindows, Mode=OneWay, StringFormat='{}Startup: {0}'}"/>
                        </TextBlock>
                    </Button>

                    <!-- Exit -->
                    <Button Grid.Column="4"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding ExitAppCommand}">
                        <TextBlock Text="❌ Exit" FontSize="12"/>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- Status Bar                                          -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Grid.Row="4"
                    Background="#10FFFFFF"
                    CornerRadius="0,0,16,16"
                    Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusBarText}"
                               Foreground="{Binding StatusBarColor}"
                               FontSize="11"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding UptimeText, StringFormat='⏱ {0}'}"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
